{
  "name": "projector",
  "version": "0.0.0",
  "description": "Web service for the following project team",
  "license": "Apache-2.0",
  "author": "Ivan Vasiliev <va3iliev.ip@gmail.com>",
  "homepage": "https://github.com/IO-an/projector/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/io-an/projector.git"
  },
  "bugs": {
    "url": "https://github.com/IO-an/projector/issues",
    "email": "va3iliev.ip@gmail.com"
  },
  "keywords": [
    "project",
    "team"
  ],
  "private": true,
  "engineStrict": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "~24.16.0",
    "npm": "~11.13.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start:web": "npm start -w @projector/web",
    "start:api": "npm start -w @projector/api",
    "build:all": "npm run build --workspaces --if-present",
    "build:libs": "npm run build --workspace=packages",
    "lint:all": "npm run lint --workspaces",
    "lint:all:fix": "npm run lint:fix --workspaces"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "webpack-merge": "^6.0.1"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
